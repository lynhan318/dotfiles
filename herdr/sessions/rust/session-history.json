              "ansi": "     ▲                   │\r\n     └─ mut cho phép đổi MŨI TÊN, không cho phép sửa Ô được trỏ tới\r\n\r\n  \u001b[0m\u001b[1mMuốn sửa NỘI DUNG thật → dùng \u001b[0m\u001b[1m\u001b[38;5;12mString\u001b[0m\r\n\r\n  \u001b[0m\u001b[38;5;4mlet mut \u001b[0mtext = \u001b[0m\u001b[2m\u001b[38;5;6mString\u001b[0m::\u001b[0m\u001b[38;5;3mfrom\u001b[0m(\u001b[0m\u001b[38;5;1m\"hello\"\u001b[0m);  \u001b[0m\u001b[38;5;2m// sở hữu data trên heap\u001b[0m\r\n  text.\u001b[0m\u001b[38;5;3mpush_str\u001b[0m(\u001b[0m\u001b[38;5;1m\" world\"\u001b[0m);               \u001b[0m\u001b[38;5;2m// ✓ SỬA/grow nội dung được\u001b[0m\r\n  text = \u001b[0m\u001b[2m\u001b[38;5;6mString\u001b[0m::\u001b[0m\u001b[38;5;3mfrom\u001b[0m(\u001b[0m\u001b[38;5;1m\"new\"\u001b[0m);            \u001b[0m\u001b[38;5;2m// ✓ và cũng gán lại được (vì có mut)\u001b[0m\r\n\r\n  Với \u001b[0m\u001b[38;5;12mString \u001b[0mthì \u001b[0m\u001b[38;5;12mmut \u001b[0mmở khoá \u001b[0m\u001b[1mcả hai \u001b[0mquyền: vừa gán lại biến, vừa sửa ruột chuỗi (vì \u001b[0m\u001b[38;5;12mString \u001b[0msở hữu buffer heap có thể grow).\r\n\r\n  ┌───────────────────┬───────────────────────────────┬───────────────────────────────────────────────┐\r\n  │                   │ \u001b[0m\u001b[38;5;12mlet mut text = \"hello\" \u001b[0m(\u001b[0m\u001b[38;5;12m&str\u001b[0m) │ \u001b[0m\u001b[38;5;12mlet mut text = String::from(\"hello\") \u001b[0m(\u001b[0m\u001b[38;5;12mString\u001b[0m) │\r\n  ├───────────────────┼───────────────────────────────┼───────────────────────────────────────────────┤\r\n  │ Gán lại biến      │ ✓                             │ ✓                                             │\r\n  ├───────────────────┼───────────────────────────────┼───────────────────────────────────────────────┤\r\n  │ Sửa/grow nội dung │ ✗                             │ ✓                                             │\r\n  └───────────────────┴───────────────────────────────┴─────────────────────────────────────────